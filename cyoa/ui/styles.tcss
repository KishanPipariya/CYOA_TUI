/* ═══════════════════════════════════════════════════════════
   CYOA TUI — External Stylesheet (styles.tcss)
   Fix #8: CSS moved out of the App class into this file.
   ═══════════════════════════════════════════════════════════ */

Screen {
    background: $background;
}

/* ── Shared Dialog Shells ───────────────────────────────────── */
.dialog-frame {
    max-width: 90%;
    max-height: 90%;
    border: thick $primary;
    background: $surface;
    padding: 1 2;
}

.dialog-frame-accent {
    border: thick $accent;
}

.dialog-frame-scroll {
    overflow: hidden auto;
}

.dialog-title {
    text-align: center;
    text-style: bold;
    margin-bottom: 1;
}

.dialog-message {
    text-align: center;
    margin-bottom: 1;
}

#startup-kicker {
    width: 100%;
    text-align: center;
    text-style: bold;
    color: $accent;
    background: $accent 12%;
    border: round $accent 40%;
    padding: 0 1;
    margin-bottom: 1;
}

#startup-message {
    width: 100%;
    background: $panel;
    border: solid $secondary 40%;
    padding: 1 2;
    margin-bottom: 1;
}

#startup-hint {
    width: 100%;
    color: $text-muted;
    text-align: center;
}

.dialog-content {
    height: 1fr;
    overflow-y: auto;
}

.dialog-list {
    height: 1fr;
    border: solid $secondary;
    margin-bottom: 1;
}

.dialog-entry {
    padding: 0 1;
}

.dialog-actions {
    align: center middle;
    height: auto;
}

.dialog-actions Button {
    width: auto;
    min-width: 12;
    margin: 0 1;
}

/* ── Notifications ───────────────────────────────────────────── */
ToastRack {
    width: auto;
    max-width: 80%;
    max-height: 100%;
    dock: top;
    align: right top;
    margin: 1 1 0 0;
    overflow-y: hidden;
}

Toast {
    width: auto;
    min-width: 20;
    max-width: 100%;
    border: solid $secondary;
    padding: 0 1;
}

Toast.-information {
    border-left: solid $success;
}

Toast.-warning {
    border-left: solid $warning;
}

Toast.-error {
    border-left: solid $error;
}

.compact-layout ToastRack {
    max-width: 90%;
    margin-right: 0;
}

.compact-layout Toast {
    min-width: 0;
}

/* ── Main Layout Containers ──────────────────────────────────── */
#workspace {
    height: 1fr;
    background: $background;
}

#main-container {
    width: 1fr;
    min-width: 64;
    padding: 1;
    background: $surface;
}

#action-panel {
    height: auto;
    max-height: 40%;
    border-top: solid $secondary 35%;
    margin: 1 0 0 0;
    padding: 1 1 0 1;
    background: $panel 80%;
}

#journal-panel, #story-map-panel {
    width: 34;
    border-left: solid $secondary 35%;
    padding: 1 1 1 0;
    background: $panel 45%;
    overflow: hidden auto;
}

#journal-panel.panel-collapsed, #story-map-panel.panel-collapsed {
    display: none;
}

/* Narrow terminals: prioritize readable story width. */
.compact-layout #main-container {
    width: 1fr;
    min-width: 0;
    padding: 1 0 0 0;
}

.compact-layout #journal-panel, .compact-layout #story-map-panel {
    width: 28;
    padding-left: 0;
}


#journal-title, #story-map-title {
    text-align: center;
    text-style: bold;
    color: $primary;
    margin-bottom: 1;
}

#journal-list {
    height: 1fr;
    background: transparent;
}

#journal-list Label {
    width: 100%;
    content-align: left middle;
}

#story-map-tree {
    height: 1fr;
    background: transparent;
}

/* ── Story Panel ───────────────────────────────────────────── */
#story-container {
    height: 1fr;
    border: none;
    padding: 1 1 0 1;
    margin: 0;
    background: $surface;
}

.story-turn {
    background: $panel 88%;
    color: $text;
    padding: 1 2;
    margin: 0 0 1 0;
    border-left: wide $accent 35%;
    border-right: solid $secondary 12%;
}

.player-choice {
    background: $accent 12%;
    color: $text;
    padding: 1 2;
    margin: 0 0 1 4;
    border-right: wide $accent 55%;
    border-left: solid $accent 20%;
    text-align: right;
}

.story-turn.current-turn {
    background: $panel;
    border-left: wide $accent;
    border-right: solid $accent 22%;
}

.story-turn.archived-turn {
    background: $panel 72%;
    color: $text-muted;
    border-left: solid $secondary 38%;
    border-right: solid $secondary 10%;
}

.player-choice.latest-choice {
    background: $accent 18%;
    border-right: wide $accent;
}

.player-choice.archived-choice {
    background: $surface 55%;
    color: $text-muted;
    border-right: solid $secondary 28%;
    border-left: solid $secondary 18%;
}

#scene-art {
    width: 100%;
    height: auto;
    color: $accent;
    text-align: center;
    /* Use monospace for ASCII art if possible, though labels usually default to terminal font */
    text-style: bold;
    margin-top: 1;
}

/* ── Status Bar (two-row stats + inventory) ──────────────── */
#status-bar {
    height: auto;
    padding: 0 0 1 0;
    margin: 0;
    border: none;
}

StatusDisplay {
    height: auto;
    background: $surface 35%;
    border: none;
    padding: 0 1;
    margin: 0;
}

#stats-row {
    height: 1;
    width: 100%;
}

#health-label {
    width: auto;
    color: $text-muted;
    margin-right: 1;
}

#health-bar {
    width: 1fr;
    height: 1;
}

#health-bar .bar--complete {
    background: $success;
    transition: background 500ms;
}

#health-bar .bar--pending {
    background: $surface;
}

.health-high #health-bar .bar--complete { background: $success; }
.health-mid #health-bar .bar--complete { background: $warning; }
.health-low #health-bar .bar--complete { background: $error; }

#stats-text {
    width: auto;
    text-align: right;
    color: $text;
}

#inventory-label {
    width: 100%;
    color: $text-muted;
    text-style: italic;
    margin-top: 0;
}

ThemeSpinner {
    text-align: center;
    color: $accent;
    height: 1;
}

/* ── Choices Panel ─────────────────────────────────────────── */
/* Fix #3: Cap height to prevent overflow on small terminals */
#choices-container {
    height: auto;
    max-height: 40%;
    border: none;
    padding: 1 0 0 0;
    margin: 0;
    overflow-y: auto;
    background: transparent;
}

/* ── Buttons ────────────────────────────────────────────────── */
Button {
    width: 100%;
    margin-bottom: 0;
    height: auto;
    min-height: 3;
}

#choices-container Button {
    margin-bottom: 1;
    background: $panel;
    color: $text;
    border: round $secondary 30%;
}

Button > .textual-button--label {
    text-align: left;
    padding-left: 2;
}

#choices-container Button > .textual-button--label {
    text-wrap: wrap;
}

#choices-container Button:focus {
    background: $accent 15%;
    border: round $accent;
    color: $text;
    text-style: bold;
}

#choices-container Button:disabled {
    background: $surface;
    color: $text-muted;
    border: round $secondary 20%;
}

/* ── Footer ────────────────────────────────────────────────── */
Footer {
    background: transparent;
    color: $text-muted;
    dock: bottom;
    padding: 0 1;
}

Footer > .footer--key {
    background: $accent 20%;
    color: $accent;
    text-style: bold;
    margin-right: 1;
}

Footer > .footer--highlight {
    background: $accent;
    color: $surface;
}

/* Ending button gets a special success variant treatment */
#btn-new-adventure {
    margin-top: 1;
}

/* ── Error Display ──────────────────────────────────────────── */
#btn-retry {
    margin-top: 1;
}

/* ── Atmosphere / Mood Shifts ────────────────────────────────── */

#main-container {
    transition: background 300ms, border 300ms;
}

/* Mysterious: Deep purples and indigo */
.mood-mysterious #story-container {
    border: thick $primary;
    background: $panel 10%;
}
.mood-mysterious #choices-container {
    border: none;
}

/* Heroic: Gold and bright highlights */
.mood-heroic #story-container {
    border: thick #FFD700;
    background: #FFD700 8%;
}
.mood-heroic #choices-container {
    border: none;
}

/* Combat: Red alerts and aggressive borders */
.mood-combat #story-container {
    border: heavy $error;
    background: $error 8%;
}
.mood-combat #choices-container {
    border: none;
}

/* Ethereal: Cyan, celestial glow */
.mood-ethereal #story-container {
    border: outer cyan;
    background: cyan 8%;
}
.mood-ethereal #choices-container {
    border: none;
}

/* Dark: Gritty grays and dim text */
.mood-dark #story-container {
    border: tall gray;
    background: gray 8%;
}
.mood-dark #choices-container {
    border: none;
}

/* Grimy: Earthy greens and browns */
.mood-grimy #story-container {
    border: heavy #556B2F;
    background: #556B2F 8%;
}
.mood-grimy #choices-container {
    border: none;
}

/* ── Utilities ──────────────────────────────────────────────── */
.hidden {
    display: none;
}

.turn-highlight {
    border: tall $accent;
    background: $accent 15%;
}

.compact-layout #story-container {
    padding: 1 0 0 0;
}

.compact-layout .story-turn {
    padding: 1 1;
}

.compact-layout .player-choice {
    margin-left: 2;
    padding: 1 1;
}

.compact-layout .story-turn.archived-turn,
.compact-layout .player-choice.archived-choice {
    color: $text;
}

.compact-layout #action-panel {
    max-height: 45%;
    padding-left: 0;
    padding-right: 0;
}

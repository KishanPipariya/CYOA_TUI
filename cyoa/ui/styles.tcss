/* ═══════════════════════════════════════════════════════════
   CYOA TUI — External Stylesheet (styles.tcss)
   Fix #8: CSS moved out of the App class into this file.
   ═══════════════════════════════════════════════════════════ */

Screen {
    background: $background;
}

/* ── Shared Dialog Shells ───────────────────────────────────── */
.dialog-frame {
    max-width: 90%;
    max-height: 90%;
    border: round $primary;
    background: $surface;
    padding: 1 2;
}

.dialog-frame-accent {
    border: round $accent;
}

.dialog-frame-scroll {
    overflow: hidden auto;
}

.dialog-title {
    text-align: center;
    text-style: bold;
    margin-bottom: 1;
}

.dialog-message {
    text-align: center;
    margin-bottom: 1;
}

#startup-kicker {
    width: 1fr;
    text-align: center;
    text-style: bold;
    color: $accent;
    background: $accent 12%;
    border: round $accent 40%;
    padding: 0 1;
    margin-bottom: 1;
}

#startup-message {
    width: 1fr;
    background: $panel;
    border: solid $secondary 40%;
    padding: 1 2;
    margin-bottom: 1;
}

#startup-hint {
    width: 1fr;
    color: $text-muted;
    text-align: center;
}

.dialog-content {
    height: 1fr;
    overflow-y: auto;
}

.dialog-list {
    height: 1fr;
    border: solid $secondary;
    margin-bottom: 1;
}

.dialog-entry {
    padding: 0 1;
}

.dialog-actions {
    align: center middle;
    width: 100%;
    height: auto;
    margin-top: 1;
}

.dialog-actions Button {
    width: 1fr;
    min-width: 12;
    margin: 0 1 0 0;
    min-height: 5;
    padding: 0;
    border: round $secondary 28%;
    background: $panel 92%;
    color: $text;
}

.dialog-actions Button:last-child {
    margin-right: 0;
}

.dialog-actions Button > .textual-button--label {
    text-align: center;
    padding: 1 2;
    text-style: bold;
}

.dialog-actions Button:focus {
    border: round $accent;
    background: $accent 16%;
    color: $text;
    tint: $accent 6%;
}

#confirm-dialog {
    background: $surface;
    border-title-color: $warning;
}

#confirm-message {
    margin-bottom: 2;
}

#btn-confirm-yes {
    background: $error 18%;
    border: round $error 70%;
    color: $text;
}

#btn-confirm-yes:focus {
    background: $error 28%;
    border: round $error;
    tint: $error 10%;
}

#btn-confirm-no {
    background: $primary 16%;
    border: round $primary 65%;
    color: $text;
}

#btn-confirm-no:focus {
    background: $primary 26%;
    border: round $primary;
    tint: $primary 8%;
}

#startup-dialog {
    background: $panel;
}

#startup-title {
    color: $text;
}

#startup-message {
    margin-bottom: 2;
}

#startup-hint {
    margin-bottom: 1;
}

#btn-startup-resume {
    background: $accent 20%;
    border: round $accent 75%;
    color: $text;
}

#btn-startup-resume:focus {
    background: $accent 30%;
    border: round $accent;
    tint: $accent 10%;
}

#btn-startup-new {
    background: $success 16%;
    border: round $success 68%;
    color: $text;
}

#btn-startup-new:focus {
    background: $success 24%;
    border: round $success;
    tint: $success 8%;
}

/* ── Notifications ───────────────────────────────────────────── */
ToastRack {
    width: 1fr;
    height: auto;
    max-height: 100%;
    dock: top;
    layer: overlay;
    align: right top;
    margin: 1 1 0 0;
    overflow-y: hidden;
}

Toast {
    width: auto;
    min-width: 20;
    max-width: 100%;
    border: solid $secondary;
    padding: 0 1;
}

Toast.-information {
    border-left: solid $success;
}

Toast.-warning {
    border-left: solid $warning;
}

Toast.-error {
    border-left: solid $error;
}

.compact-layout ToastRack {
}

.compact-layout Toast {
    min-width: 0;
}

.compact-layout .dialog-frame {
    padding: 1;
}

.compact-layout .dialog-actions {
    margin-top: 0;
}

.compact-layout .dialog-actions Button {
    min-height: 3;
}

.compact-layout .dialog-actions Button > .textual-button--label {
    padding: 0 1;
}

.compact-layout #startup-kicker,
.compact-layout .dialog-title,
.compact-layout #startup-hint,
.compact-layout #startup-buttons {
    margin-bottom: 0;
}

.compact-layout #startup-message {
    margin-bottom: 1;
    padding: 0 1;
}

/* ── Main Layout Containers ──────────────────────────────────── */
#workspace {
    height: 1fr;
    background: $background;
    layout: horizontal;
}

#main-container {
    width: 1fr;
    height: 1fr;
    min-width: 64;
    padding: 1;
    background: $surface;
    layout: vertical;
    overflow: hidden;
}

#action-panel {
    height: auto;
    border-top: solid $secondary 35%;
    margin: 1 0 0 0;
    padding: 1 1 0 1;
    background: $panel 80%;
    layout: vertical;
    overflow: hidden;
}

#action-dock {
    display: none;
}

#journal-panel, #story-map-panel {
    width: 34;
    border-left: solid $secondary 20%;
    padding: 1;
    background: $surface;
    overflow: hidden auto;
}

#journal-panel.panel-collapsed, #story-map-panel.panel-collapsed {
    display: none;
}

/* Narrow terminals: prioritize readable story width. */
.compact-layout #main-container {
    width: 1fr;
    min-width: 0;
    padding: 1 0 0 0;
}

.compact-layout #journal-panel, .compact-layout #story-map-panel {
    width: 28;
    padding: 1 0 1 1;
}

.side-panel-shell {
    width: 100%;
    height: 1fr;
    background: $panel 58%;
    border: round $secondary 18%;
    padding: 1;
}

.side-panel-journal {
    border-top: wide $accent 45%;
}

.side-panel-map {
    border-top: wide $primary 45%;
}

.side-panel-kicker {
    width: 100%;
    color: $text-muted;
    text-align: center;
    margin: 0 0 1 0;
}

.side-panel-body {
    width: 100%;
    height: 1fr;
    background: $surface 70%;
    border: solid $secondary 12%;
    padding: 1;
}

.side-panel-section-title {
    width: 100%;
    color: $accent;
    text-style: bold;
    margin: 0 0 1 0;
}

#journal-title, #story-map-title {
    text-align: center;
    text-style: bold;
    color: $text;
    background: $background 35%;
    border: round $secondary 18%;
    padding: 0 1;
    margin-bottom: 1;
}

#journal-list {
    height: 1fr;
    background: transparent;
    border: none;
}

#journal-list > ListItem {
    padding: 0 1;
    margin: 0 0 1 0;
    background: $panel 55%;
    border-left: thick $secondary 28%;
}

#journal-list > ListItem.--highlight,
#journal-list > ListItem:focus,
#journal-list > ListItem:hover {
    background: $accent 12%;
    border-left: thick $accent 70%;
}

#journal-list Label {
    width: 100%;
    content-align: left middle;
    color: $text;
}

#story-map-tree {
    height: 1fr;
    background: transparent;
    border: none;
    padding: 0;
}

#story-map-tree .tree--guides {
    color: $secondary;
}

#story-map-tree .tree--label {
    color: $text;
}

#story-map-tree .tree--cursor {
    background: $accent 16%;
    color: $text;
    text-style: bold;
}

.compact-layout .side-panel-shell {
    padding: 1 0 0 0;
    border-left: none;
    border-right: none;
    border-bottom: none;
}

.compact-layout .side-panel-body {
    padding: 1 0 0 0;
}

/* ── Story Panel ───────────────────────────────────────────── */
#story-container {
    height: 1fr;
    min-height: 10;
    border: none;
    padding: 1 1 0 1;
    margin: 0;
    background: $surface;
    overflow-x: hidden;
}

#story-container.loading-state {
    overflow-y: hidden;
}

.story-turn {
    background: $panel 88%;
    color: $text;
    padding: 1 2;
    margin: 0 0 1 0;
    border-left: solid $accent 45%;
    border-right: solid $secondary 12%;
}

.player-choice {
    background: $accent 12%;
    color: $text;
    padding: 1 2;
    margin: 0 0 1 4;
    border-right: wide $accent 55%;
    border-left: solid $accent 20%;
    text-align: right;
}

.story-turn.current-turn {
    background: $panel;
    border-left: solid $accent;
    border-right: solid $accent 22%;
}

.story-turn.archived-turn {
    background: $panel 72%;
    color: $text-muted;
    border-left: solid $secondary 38%;
    border-right: solid $secondary 10%;
}

.player-choice.latest-choice {
    background: $accent 18%;
    border-right: wide $accent;
}

.player-choice.archived-choice {
    background: $surface 55%;
    color: $text-muted;
    border-right: solid $secondary 28%;
    border-left: solid $secondary 18%;
}

#scene-art {
    width: 100%;
    height: auto;
    color: $accent;
    text-align: center;
    /* Use monospace for ASCII art if possible, though labels usually default to terminal font */
    text-style: bold;
    margin-top: 1;
}

/* ── Status Bar (two-row stats + inventory) ──────────────── */
#status-bar {
    width: 100%;
    height: auto;
    min-height: 8;
    padding: 0 0 1 0;
    margin: 0;
    border: none;
    overflow: hidden;
}

StatusDisplay {
    height: auto;
    background: $panel 46%;
    border: round $secondary 18%;
    padding: 1;
    margin: 0;
}

#stats-row {
    height: 1;
    width: 100%;
}

#status-meta-row {
    height: auto;
    width: 100%;
    margin-top: 1;
}

#health-label {
    width: auto;
    color: $text-muted;
    margin-right: 1;
}

#health-bar {
    width: 1fr;
    height: 1;
}

#health-bar .bar--complete {
    background: $success;
    transition: background 500ms;
}

#health-bar .bar--pending {
    background: $surface;
}

.health-high #health-bar .bar--complete { background: $success; }
.health-mid #health-bar .bar--complete { background: $warning; }
.health-low #health-bar .bar--complete { background: $error; }

#health-value {
    width: 6;
    text-align: right;
    color: $text;
    text-style: bold;
    margin-left: 1;
}

#stats-text {
    width: 1fr;
    height: 1;
    color: $text;
    background: $surface 42%;
    border: round $secondary 18%;
    padding: 0 1;
    margin-right: 1;
    text-wrap: nowrap;
    overflow: hidden;
}

#runtime-text {
    width: 1fr;
    height: 1;
    text-align: right;
    color: $text;
    background: $surface 42%;
    border: round $secondary 18%;
    padding: 0 1;
    text-wrap: nowrap;
    overflow: hidden;
}

#inventory-label, #objectives-label, #directives-label {
    width: 100%;
    color: $text;
    background: $surface 28%;
    border-left: wide $accent 28%;
    padding: 0 1;
    margin-top: 1;
}

#inventory-label {
    color: $text-muted;
}

.compact-layout StatusDisplay {
    padding: 1 0;
}

.compact-layout #status-meta-row {
    margin-top: 0;
}

.compact-layout #stats-text,
.compact-layout #runtime-text {
    margin-right: 0;
    margin-top: 1;
}

ThemeSpinner {
    text-align: center;
    color: $accent;
    height: 1;
}

/* ── Choices Panel ─────────────────────────────────────────── */
/* Fix #3: Cap height to prevent overflow on small terminals */
#choices-container {
    width: 100%;
    height: auto;
    min-height: 6;
    max-height: 12;
    border: none;
    padding: 0;
    margin: 0;
    overflow-y: auto;
    background: transparent;
}

#choices-container.loading-state {
    display: none;
}

/* ── Buttons ────────────────────────────────────────────────── */
Button {
    width: 100%;
    margin-bottom: 0;
    height: auto;
    min-height: 3;
}

#choices-container Button {
    margin-bottom: 1;
    min-height: 4;
    padding: 0;
    background: $panel 92%;
    color: $text;
    border: round $secondary 42%;
    border-left: solid $secondary 52%;
    tint: transparent;
}

Button > .textual-button--label {
    text-align: left;
    padding-left: 2;
}

#choices-container Button > .textual-button--label {
    text-wrap: wrap;
    padding: 1 2;
    text-style: none;
}

#choices-container Button:focus {
    background: $accent 16%;
    border: round $accent;
    border-left: solid $accent;
    color: $text;
    tint: $accent 9%;
}

#choices-container Button:disabled {
    background: $surface 88%;
    color: $text-muted;
    border: round $secondary 24%;
    border-left: solid $warning 38%;
    tint: transparent;
}

#choices-container Button.choice-card-available {
    background: $panel;
    border-left: solid $accent 55%;
}

#choices-container Button.choice-card-available:hover {
    background: $accent 8%;
    border: round $accent 72%;
    border-left: solid $accent 78%;
}

#choices-container Button.choice-card-locked {
    background: $warning 7%;
    color: $text-muted;
    border: round $warning 24%;
    border-left: solid $warning 60%;
}

#choices-container Button.choice-card-error {
    background: $error 12%;
    border: round $error 28%;
    border-left: solid $error 70%;
}

#choices-container Button.choice-card-ending {
    background: $success 14%;
    border: round $success 30%;
    border-left: solid $success 72%;
}

.compact-layout #choices-container Button {
    min-height: 3;
}

.compact-layout #choices-container Button > .textual-button--label {
    padding: 0 1;
}

/* ── Footer ────────────────────────────────────────────────── */
Footer {
    background: transparent;
    color: $text-muted;
    dock: bottom;
    padding: 0 1;
    border-top: solid $secondary 10%;
}

Footer > .footer--key {
    background: $accent 14%;
    color: $accent;
    text-style: bold;
    margin-right: 1;
    padding: 0 1;
}

Footer > .footer--highlight {
    background: $accent 22%;
    color: $surface;
}

/* Ending button gets a special success variant treatment */
#btn-new-adventure {
    margin-top: 1;
}

/* ── Error Display ──────────────────────────────────────────── */
#btn-retry {
    margin-top: 1;
}

/* ── Atmosphere / Mood Shifts ────────────────────────────────── */

#main-container {
    transition: background 300ms, border 300ms;
}

/* Mysterious: Deep indigo with arcane highlights */
.mood-mysterious #story-container {
    border-left: wide $primary;
    background: $primary 7%;
}
.mood-mysterious #choices-container {
    background: $primary 3%;
}
.mood-mysterious #choices-container Button:focus {
    background: $primary 16%;
    border: round $primary;
    border-left: wide $accent;
}
.mood-mysterious #status-display,
.mood-mysterious .side-panel-shell {
    border: round $primary 32%;
    background: $primary 8%;
}

/* Heroic: Brass and lifted contrast */
.mood-heroic #story-container {
    border-left: wide #FFD700;
    background: #FFD700 8%;
}
.mood-heroic #choices-container {
    background: #FFD700 3%;
}
.mood-heroic #choices-container Button:focus {
    background: #FFD700 16%;
    border: round #FFD700;
    border-left: wide #FFD700;
    color: $text;
}
.mood-heroic #status-display,
.mood-heroic .side-panel-shell {
    border: round #FFD700 30%;
    background: #FFD700 7%;
}

/* Combat: Sharper danger treatment without overpowering the screen */
.mood-combat #story-container {
    border-left: wide $error;
    background: $error 8%;
}
.mood-combat #choices-container {
    background: $error 3%;
}
.mood-combat #choices-container Button:focus {
    background: $error 16%;
    border: round $error;
    border-left: wide $error;
}
.mood-combat #status-display,
.mood-combat .side-panel-shell {
    border: round $error 34%;
    background: $error 7%;
}

/* Ethereal: Cool cyan glow */
.mood-ethereal #story-container {
    border-left: wide cyan;
    background: cyan 8%;
}
.mood-ethereal #choices-container {
    background: cyan 3%;
}
.mood-ethereal #choices-container Button:focus {
    background: cyan 16%;
    border: round cyan;
    border-left: wide cyan;
}
.mood-ethereal #status-display,
.mood-ethereal .side-panel-shell {
    border: round cyan 34%;
    background: cyan 7%;
}

/* Dark: Low-light slate and reduced glow */
.mood-dark #story-container {
    border-left: wide gray;
    background: gray 8%;
}
.mood-dark #choices-container {
    background: gray 3%;
}
.mood-dark #choices-container Button:focus {
    background: gray 16%;
    border: round gray;
    border-left: wide gray;
}
.mood-dark #status-display,
.mood-dark .side-panel-shell {
    border: round gray 30%;
    background: gray 7%;
}

/* Grimy: Mossy, weathered surfaces */
.mood-grimy #story-container {
    border-left: wide #556B2F;
    background: #556B2F 8%;
}
.mood-grimy #choices-container {
    background: #556B2F 3%;
}
.mood-grimy #choices-container Button:focus {
    background: #556B2F 16%;
    border: round #556B2F;
    border-left: wide #556B2F;
}
.mood-grimy #status-display,
.mood-grimy .side-panel-shell {
    border: round #556B2F 30%;
    background: #556B2F 7%;
}

.mood-mysterious #action-panel,
.mood-heroic #action-panel,
.mood-combat #action-panel,
.mood-ethereal #action-panel,
.mood-dark #action-panel,
.mood-grimy #action-panel {
    border-top: solid $accent 32%;
}

.mood-mysterious ThemeSpinner,
.mood-heroic ThemeSpinner,
.mood-combat ThemeSpinner,
.mood-ethereal ThemeSpinner,
.mood-dark ThemeSpinner,
.mood-grimy ThemeSpinner {
    text-style: bold;
}

/* ── Utilities ──────────────────────────────────────────────── */
.hidden {
    display: none;
}

.turn-highlight {
    border: tall $accent;
    background: $accent 15%;
}

.compact-layout #story-container {
    padding: 1 0 0 0;
}

.compact-layout .story-turn {
    padding: 1 1;
}

.compact-layout .player-choice {
    margin-left: 2;
    padding: 1 1;
}

.compact-layout .story-turn.archived-turn,
.compact-layout .player-choice.archived-choice {
    color: $text;
}

.compact-layout #action-panel {
    padding-left: 0;
    padding-right: 0;
}

.compact-layout #action-dock {
    display: none;
}

.compact-layout #status-bar {
    width: 100%;
    padding-right: 0;
}

.compact-layout #choices-container {
    max-height: 14;
    padding: 0 1;
}

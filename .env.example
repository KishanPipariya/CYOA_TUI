# Optional Neo4j graph persistence
# Leave these unset if you do not want graph persistence.
CYOA_ENABLE_GRAPH_DB=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=cyoa_app
NEO4J_PASSWORD=change-me

# Optional runtime overrides
# LLM_PROVIDER=llama_cpp
# LLM_MODEL_PATH=/absolute/path/to/model.gguf
# LLM_PRESET=balanced
# APP_RUNTIME_PRESET=local-fast
